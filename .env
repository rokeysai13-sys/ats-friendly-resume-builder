# ─── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=resume-atelier-prod-key-2024-obsidian-secure-v1.2
JWT_SECRET_KEY=jwt-token-secret-resume-atelier-2024-v1.2

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite for local development (no psycopg2 required)
DATABASE_URL=sqlite:///resume_builder.db
# Uncomment for PostgreSQL when ready:
# DATABASE_URL=postgresql://user:pass@localhost:5432/resume_builder

# ─── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=google-gemini
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_PROVIDER=google-gemini
LLM_FALLBACK_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=5
LLM_MAX_DAILY_CALLS_PER_USER=50

# ─── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App URLs ──────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ─── Flask ─────────────────────────────────────────────────────────────────────
FLASK_APP=app
FLASK_ENV=development

# Phase 2: Google Gemini
GEMINI_API_KEY=AIzaSyCt5ej4HSZ7U-E1f8jTgXuATQZeWYz_MhU
